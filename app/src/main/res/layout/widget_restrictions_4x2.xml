<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root_4x2"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_4x2_bg"
    android:padding="12dp">

    <!-- 빈 상태: 등록된 제한 앱 없음 -->
    <LinearLayout
        android:id="@+id/widget_empty"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/widget_empty_message"
            android:textColor="@color/widget_dark_title"
            android:textSize="12sp"
            android:gravity="center" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/widget_empty_add_restrictions"
            android:textColor="@color/widget_dark_sub"
            android:textSize="11sp"
            android:gravity="center"
            android:layout_marginTop="4dp" />
    </LinearLayout>

    <!-- 메인 컨텐츠 -->
    <LinearLayout
        android:id="@+id/widget_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:visibility="visible">

        <!-- ── 지정 시간 제한 섹션 ── -->
        <LinearLayout
            android:id="@+id/section_time_spec"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_vertical"
            android:paddingRight="10dp">

            <!-- 섹션 타이틀 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="시간 제한"
                android:textColor="@color/widget_dark_title"
                android:textSize="12sp" />

            <!-- 메인 숫자: N개 제한 중 -->
            <TextView
                android:id="@+id/count_time_spec"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/widget_dark_text_primary"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginTop="4dp" />

            <!-- 서브: 총 N개 등록 -->
            <TextView
                android:id="@+id/sub_time_spec"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/widget_dark_sub"
                android:textSize="11sp"
                android:layout_marginTop="2dp" />

            <!-- 프로그레스바 (제한 중 / 전체 비율) -->
            <ProgressBar
                android:id="@+id/progress_time_spec"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="4dp"
                android:layout_marginTop="8dp"
                android:max="100"
                android:progress="0"
                android:progressTint="@color/widget_dark_progress"
                android:progressBackgroundTint="@color/widget_dark_progress_bg" />
        </LinearLayout>

        <!-- 세로 구분선: RemoteViews는 android.view.View 미지원 → ImageView + shape -->
        <ImageView
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="4dp"
            android:background="@drawable/widget_divider_vertical"
            android:contentDescription="@null"
            android:scaleType="fitXY" />

        <!-- ── 하루 사용량 제한 섹션 ── -->
        <LinearLayout
            android:id="@+id/section_daily"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_vertical"
            android:paddingLeft="10dp">

            <!-- 섹션 타이틀 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="사용량 제한"
                android:textColor="@color/widget_dark_title"
                android:textSize="12sp" />

            <!-- 메인 숫자: NNN분 사용 -->
            <TextView
                android:id="@+id/count_daily"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/widget_dark_text_primary"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginTop="4dp" />

            <!-- 서브: 한도 NNN분 -->
            <TextView
                android:id="@+id/sub_daily"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/widget_dark_sub"
                android:textSize="11sp"
                android:layout_marginTop="2dp" />

            <!-- 프로그레스바 - 정상 (보라) -->
            <ProgressBar
                android:id="@+id/progress_daily_normal"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="4dp"
                android:layout_marginTop="8dp"
                android:max="100"
                android:progress="0"
                android:progressTint="@color/widget_dark_progress"
                android:progressBackgroundTint="@color/widget_dark_progress_bg"
                android:visibility="gone" />

            <!-- 프로그레스바 - 초과 (빨강) -->
            <ProgressBar
                android:id="@+id/progress_daily_exceeded"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="4dp"
                android:layout_marginTop="8dp"
                android:max="100"
                android:progress="100"
                android:progressTint="@color/widget_dark_exceeded"
                android:progressBackgroundTint="@color/widget_dark_progress_bg"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
