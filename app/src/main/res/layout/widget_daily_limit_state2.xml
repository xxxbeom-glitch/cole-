<?xml version="1.0" encoding="utf-8"?>
<!-- RemoteViews — 앱 2개 -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_daily_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_4x2_bg"
    android:orientation="vertical"
    android:padding="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/widget_daily_header_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:includeFontPadding="false"
            android:fontFamily="sans-serif-medium"
            android:maxLines="1"
            android:text="@string/widget_daily_header_title"
            android:textColor="@color/widget_dark_title"
            android:textSize="14sp" />

        <ImageView
            android:id="@+id/widget_daily_refresh"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:contentDescription="@string/widget_daily_refresh_cd"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_widget_refresh" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="34dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/widget_daily_limit_empty_box"
        android:gravity="top"
        android:orientation="vertical"
        android:paddingHorizontal="6dp"
        android:paddingVertical="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/widget_daily_row0_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:textColor="@color/widget_dark_text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_daily_row0_usage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:ellipsize="end"
                android:includeFontPadding="false"
                android:fontFamily="sans-serif-medium"
                android:maxLines="1"
                android:textColor="@color/widget_dark_title"
                android:textSize="13sp" />
        </LinearLayout>

        <ProgressBar
            android:id="@+id/widget_daily_row0_progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:layout_marginTop="5dp"
            android:max="100"
            android:minHeight="6dp"
            android:progress="0"
            android:progressBackgroundTint="@color/widget_dark_progress_bg"
            android:progressTint="@color/widget_dark_progress" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="34dp"
        android:layout_marginTop="4dp"
        android:background="@drawable/widget_daily_limit_empty_box"
        android:gravity="top"
        android:orientation="vertical"
        android:paddingHorizontal="6dp"
        android:paddingVertical="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/widget_daily_row1_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:textColor="@color/widget_dark_text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_daily_row1_usage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:ellipsize="end"
                android:includeFontPadding="false"
                android:fontFamily="sans-serif-medium"
                android:maxLines="1"
                android:textColor="@color/widget_dark_title"
                android:textSize="13sp" />
        </LinearLayout>

        <ProgressBar
            android:id="@+id/widget_daily_row1_progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:layout_marginTop="5dp"
            android:max="100"
            android:minHeight="6dp"
            android:progress="0"
            android:progressBackgroundTint="@color/widget_dark_progress_bg"
            android:progressTint="@color/widget_dark_progress" />
    </LinearLayout>
</LinearLayout>
